AIRFLOW_UID=50000

# Extra pip packages for all Airflow containers (DAG import + task runtime). Restart stack after change.
_PIP_ADDITIONAL_REQUIREMENTS=duckdb

# PostgreSQL (used by postgres service and Airflow DB / Celery result backend URLs)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Celery broker — no password in URL if Redis has no auth (dev)
AIRFLOW_CELERY_BROKER_URL=redis://redis:6379/0

# Airflow API JWT signing (set a long random string for non-dev)
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret_change_in_production

# First Airflow UI user (airflow-init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# MinIO — own containers; Console http://localhost:9001, S3 API from other containers: http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_BUCKET=datalake
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
